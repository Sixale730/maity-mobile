# Environment variables (secrets)
.env
.env.local
.env.*.local
*.env

# Keep template files
!.env.template
!.env.example

# MCP config (may contain API keys)
.mcp.json

# Keystore files (Android signing)
*.keystore
*.jks
key.properties

# Private documentation (contains credentials)
docs/ANDROID_RELEASE_SETUP.md

# Firebase config (may contain sensitive project info)
# Uncomment if these contain sensitive data you don't want public
# google-services.json
# GoogleService-Info.plist

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
nul
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Generated files (regenerate with: flutter pub run build_runner build)
*.g.dart
lib/gen/
lib/l10n/app_localizations*.dart

# Generated plugin registrants (regenerated by flutter pub get)
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Runner/GeneratedPluginRegistrant.m
macos/Flutter/GeneratedPluginRegistrant.swift
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugins.cmake

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
# Claude Code local settings
.claude/settings.local.json

# iOS generated (regenerated by pod install / flutter pub get)
ios/.symlinks/
ios/Pods/
ios/Runner.xcworkspace/
ios/Flutter/Flutter.podspec

# iOS flavor configs (contain Google/Firebase project keys)
ios/Config/
